        {"name":"Update Attendance","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"PUT","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"attendanceDate\": \"2026-03-29\",\n  \"clockInAt\": \"2026-03-29T03:30:00Z\",\n  \"clockOutAt\": \"2026-03-29T12:30:00Z\",\n  \"workFromHome\": false,\n  \"notes\": \"Adjusted manually\"\n}"},"url":"{{baseUrl}}/api/v1/attendance/{{attendanceId}}"}}
