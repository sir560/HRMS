    {
      "name": "Auth",
      "item": [
        {"name":"Register Company","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"companyName\": \"HRMS\",\n  \"companyCode\": \"HRMS\",\n  \"adminFirstName\": \"Admin\",\n  \"adminLastName\": \"User\",\n  \"adminEmail\": \"admin@gmail.com\",\n  \"adminPassword\": \"admin12345\",\n  \"phoneNumber\": \"9999999999\"\n}"},"url":"{{baseUrl}}/api/v1/auth/register-company"}},
        {"name":"Login","event":[{"listen":"test","script":{"type":"text/javascript","exec":["if (pm.response.code === 200) {","  const json = pm.response.json();","  pm.collectionVariables.set('accessToken', json.data.accessToken);","  pm.collectionVariables.set('refreshToken', json.data.refreshToken);","}"]}}],"request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"companyCode\": \"{{companyCode}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"},"url":"{{baseUrl}}/api/v1/auth/login"}},
        {"name":"Refresh Token","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"},"url":"{{baseUrl}}/api/v1/auth/refresh"}},
        {"name":"Logout","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"},"url":"{{baseUrl}}/api/v1/auth/logout"}},
        {"name":"Forgot Password","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"companyCode\": \"{{companyCode}}\",\n  \"email\": \"{{email}}\"\n}"},"url":"{{baseUrl}}/api/v1/auth/forgot-password"}},
        {"name":"Reset Password","request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"companyCode\": \"{{companyCode}}\",\n  \"email\": \"{{email}}\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"newPassword123\"\n}"},"url":"{{baseUrl}}/api/v1/auth/reset-password"}},
        {"name":"Me","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/api/v1/auth/me"}}
      ]
    },
    {
