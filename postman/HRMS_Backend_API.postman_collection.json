        {"name":"Update Employee","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"PUT","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phoneNumber\": \"+919999999999\",\n  \"designationId\": {{designationId}},\n  \"dateOfJoining\": \"2024-01-15\",\n  \"employmentStatus\": \"ACTIVE\",\n  \"departmentId\": {{departmentId}},\n  \"active\": true\n}"},"url":"{{baseUrl}}/api/v1/employees/{{employeeId}}"}},
        {"name":"Delete Employee","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"DELETE","url":"{{baseUrl}}/api/v1/employees/{{employeeId}}"}},
        {"name":"Get Employee Documents","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/api/v1/employees/{{employeeId}}/documents"}},
        {"name":"Upload Employee Document","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"POST","body":{"mode":"formdata","formdata":[{"key":"file","type":"file","src":""},{"key":"documentType","value":"GENERAL","type":"text"}]},"url":"{{baseUrl}}/api/v1/employees/{{employeeId}}/documents"}},
        {"name":"Delete Employee Document","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"DELETE","url":"{{baseUrl}}/api/v1/employees/{{employeeId}}/documents/{{employeeDocumentId}}"}},
        {"name":"Download Employee Document","request":{"auth":{"type":"bearer","bearer":[{"key":"token","value":"{{accessToken}}","type":"string"}]},"method":"GET","url":"{{baseUrl}}/api/v1/employees/{{employeeId}}/documents/{{employeeDocumentId}}/download"}}
